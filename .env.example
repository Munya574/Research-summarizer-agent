# Anthropic Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Full cookie header value from your Nightshift session (e.g. "sb-xxx-auth-token=...")
NIGHTSHIFT_SESSION_COOKIE=sb-xxx-auth-token=your-token-here

# Your Nightshift provider profile ID (visible in your profile URL or settings)
NIGHTSHIFT_PROFILE_ID=your-profile-id-here

# Nightshift base URL (leave as-is unless using a staging environment)
NIGHTSHIFT_BASE_URL=https://nightshift-agi.com
